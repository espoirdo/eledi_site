@push('scripts')
<script src="https://maps.googleapis.com/maps/api/js?key={{ env('GOOGLE_MAPS_API_KEY') }}&libraries=places&callback=initEventMap" async defer></script>
<script>
    function eventCreator(initial = window.__eventCreatorInitial || {}) {
        return {
            step: 1,
            event: {
                titre: initial.titre || '',
                description: initial.description || '',
                category_id: initial.category_id || '',
                lieu: initial.lieu || '',
                date_heure: initial.date_heure || '',
                heure: initial.heure || '',
                prix: initial.prix || '',
                is_featured: initial.is_featured === '1' || initial.is_featured === 1 || false,
                latitude: initial.latitude || '',
                longitude: initial.longitude || '',
                tickets: initial.tickets || [{ nom: 'Entrée générale', prix: 0, quantite: 10 }],
                premium_options: initial.premium_options || [],
                customer_name: initial.customer_name || @js(auth()->user()->name ?? ''),
                customer_email: initial.customer_email || @js(auth()->user()->email ?? ''),
                imagePreview: null,
            },

            get dateLabel() {
                if (! this.event.date_heure) {
                    return null;
                }

                return this.event.date_heure + (this.event.heure ? ' à ' + this.event.heure : '');
            },

            addTicket() {
                this.event.tickets.push({ nom: '', prix: 0, quantite: 1 });
            },

            removeTicket(index) {
                if (this.event.tickets.length > 1) {
                    this.event.tickets.splice(index, 1);
                }
            },

            formattedPrice(value) {
                const amount = Number(value || 0);
                return new Intl.NumberFormat('fr-FR', { style: 'currency', currency: 'XOF', maximumFractionDigits: 0 }).format(amount);
            },

            previewCoverImage(event) {
                const file = event.target.files[0];
                if (! file) {
                    this.event.imagePreview = null;
                    return;
                }

                this.event.imagePreview = URL.createObjectURL(file);
            },

            initAutocomplete() {
                window.initEventMap = () => {
                    const input = document.getElementById('lieu');
                    if (! input || ! window.google) {
                        return;
                    }

                    const autocomplete = new window.google.maps.places.Autocomplete(input, {
                        componentRestrictions: { country: 'tg' },
                        fields: ['formatted_address', 'geometry'],
                        types: ['geocode'],
                    });

                    const map = new window.google.maps.Map(document.getElementById('map'), {
                        center: { lat: 6.1725, lng: 1.2314 },
                        zoom: 12,
                    });

                    const marker = new window.google.maps.Marker({
                        map,
                    });

                    autocomplete.addListener('place_changed', () => {
                        const place = autocomplete.getPlace();
                        if (! place.geometry) {
                            return;
                        }

                        this.event.lieu = place.formatted_address;
                        this.event.latitude = place.geometry.location.lat();
                        this.event.longitude = place.geometry.location.lng();
                        map.setCenter(place.geometry.location);
                        marker.setPosition(place.geometry.location);
                    });
                };
            }
        };
    }
</script>
@endpush

